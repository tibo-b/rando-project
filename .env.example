# ============================================================
# FICHIER MODÈLE — Copie ce fichier en ".env" et remplis
# les vraies valeurs. Ne jamais commiter le fichier ".env".
# ============================================================

# --- Base de données PostgreSQL ---
POSTGRES_DB=rando_db
POSTGRES_USER=rando_user
POSTGRES_PASSWORD=change_me_strong_password

# URL de connexion utilisée par Next.js
DATABASE_URL="postgres://rando_user:change_me_strong_password@localhost:5432/rando_db"

# --- n8n (outil d'automatisation) ---
N8N_ADMIN_USER=admin
N8N_ADMIN_PASSWORD=change_me_strong_password
N8N_DB_NAME=n8n_db
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_WEBHOOK_URL=http://localhost:5678/

# --- Next.js ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Cloudflare R2 (stockage fichiers GPX + photos) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=rando-media
NEXT_PUBLIC_CDN_URL=

# --- Claude API (génération automatique des descriptions) ---
ANTHROPIC_API_KEY=

# --- Sécurité admin ---
ADMIN_SECRET=change_me_random_string_32_chars
REVALIDATE_SECRET=change_me_another_random_string
